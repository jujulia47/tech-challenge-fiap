{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXTAUTH_API_URL",
        "NEXT_PUBLIC_API_URL",
        "DOCKER",
        "DASHBOARD_URL",
        "TRANSACTIONS_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
